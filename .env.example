# Shared
ENV=local

# Postgres
POSTGRES_DB=stockintelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_PORT=8000
BACKEND_PUBLIC_BASE_URL=http://localhost:8000
ML_SERVICE_URL=http://ml:8001

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000

# LLM explanation layer: none | openai | anthropic | ollama
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Data providers (optional)
ALPHAVANTAGE_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=
ALLOW_YAHOO_FALLBACK=true
MARKET_UNIVERSE=
MARKET_ALPHA_QUOTE_LIMIT=12
MARKET_FINNHUB_QUOTE_LIMIT=20
MARKET_LIVE_MAX_AGE_SECONDS=90
NEWS_LIVE_MAX_AGE_SECONDS=300
LIVE_WARM_INTERVAL_SECONDS=75
AUTO_SYNC_SYMBOLS_ON_STARTUP=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MARKET_FETCH_TIMEOUT_SECONDS=8
MARKET_CACHE_SOFT_STALE_SECONDS=1200
MARKET_YAHOO_FALLBACK_LIMIT=45
MARKET_STOOQ_QUOTE_LIMIT=30

# Pipeline scheduler
TICKERS=AAPL,MSFT,NVDA,TSLA,AMZN,GOOGL
PIPELINE_TIMEZONE=America/New_York
PIPELINE_DAILY_REFRESH_TIME=05:15
LIVE_FEED_ENABLED=true
LIVE_FEED_REFRESH_MINUTES=15
NEWS_RSS_SOURCES=google_news_rss,yahoo_finance_rss
